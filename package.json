{
	"name": "@vinhnnn/dev-workflow",
	"version": "2.1.0",
	"description": "Drops a single dev-workflow.md into your project. Claude Code reads it, asks the project-specific questions, and scaffolds from there. No multi-file template.",
	"type": "module",
	"bin": {
		"dev-workflow": "./bin.mjs"
	},
	"files": [
		"bin.mjs",
		"src",
		"templates",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"test": "node --test tests/*.test.mjs",
		"lint": "echo 'no lint configured yet'"
	},
	"keywords": [
		"workflow",
		"scaffolder",
		"sprint",
		"release",
		"cli"
	],
	"author": "vinhnnn",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/vinhnhq/dev-workflow.git"
	},
	"bugs": {
		"url": "https://github.com/vinhnhq/dev-workflow/issues"
	},
	"homepage": "https://github.com/vinhnhq/dev-workflow#readme",
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	}
}
